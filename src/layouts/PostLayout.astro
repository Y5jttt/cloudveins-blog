---
// 文章详情页排版:复用模板 .prose (首字下沉 / 引用块 / justify)
import Divider from '../components/Divider.astro';
import type { CollectionEntry } from 'astro:content';

interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
const { title, subtitle, date, tags } = post.data;
const dateLabel = new Date(date).toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<article class="chapter" style="max-width:780px;">
  <a class="post-back" href="/" onclick="if(history.length>1){history.back();return false;}">← 返回</a>
  <p class="kicker reveal">Journal · 测绘记</p>
  <h2 class="ch-title reveal" style="--d:.1s">{title}<span>{subtitle ?? ''}</span></h2>
  <div class="post-meta reveal" style="--d:.15s;margin-top:1.4rem;">
    {dateLabel} · ∞ 次探测
  </div>
  {tags.length > 0 && (
    <div class="tags reveal" style="--d:.2s">
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}
</article>

<Divider />

<section class="chapter" style="max-width:780px;padding-top:1rem;">
  <div class="prose reveal" style="--d:.1s">
    <slot />
  </div>
</section>
